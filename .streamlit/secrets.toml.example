# Add these in Streamlit Cloud: App settings → Secrets

REVIEWER_PASSWORD = "choose-a-strong-shared-password"

[admin_credentials]
admin = "choose-a-strong-admin-password"

[senior_credentials]
senior = "choose-a-strong-senior-password"

# Required for multi-reviewer cloud storage (run supabase/schema.sql first)
# SUPABASE_URL = "https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"
