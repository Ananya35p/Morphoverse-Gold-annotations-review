# Add these in Streamlit Cloud: App settings → Secrets

REVIEWER_PASSWORD = "choose-a-strong-shared-password"

[admin_credentials]
admin = "choose-a-strong-admin-password"

# Required for saving reviews on Streamlit Cloud (otherwise submissions are lost on restart)
# SUPABASE_URL = "https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"
